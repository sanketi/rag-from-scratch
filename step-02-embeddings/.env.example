# CIS (Workday Corporate Inference Service) — ml-eng-stg / s0010
# Docs: https://docs.ml.inday.io/cis/clients/connecting-to-the-cis/
# Requires VPN + /etc/hosts entry (see README)

CIS_ROOT=https://s0010-ml-https.s0010.us-west-2.awswd/ml/inference/cis
CIS_API_KEY=bypass-auth
# CIS_FEATURE_KEY=rag-from-scratch, your.username

# Default embedding model (provider/model — overridable in the UI)
CIS_EMBED_PROVIDER=workday
CIS_EMBED_MODEL=msmarco_distilbert_multilingual

# Disable TLS verification for internal Workday certs (dev/eng only)
CIS_INSECURE_TLS=true

PORT=3001
